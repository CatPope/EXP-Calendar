{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(node -c *)",
      "Bash(node install.mjs)",
      "Edit(.claude/compact.md)",
      "Write(.claude/compact.md)",
      "Bash(gh workflow:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(rm:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git reset --hard *)",
      "Bash(gh pr merge *)",
      "Edit(.claude/settings.local.json)",
      "Write(.claude/settings.local.json)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  }
}
