# =====================================================================
# EXP Calendar — 환경 변수 예시
# 사용법:  Copy-Item .env.example .env   (Windows PowerShell)
#         cp .env.example .env          (macOS / Linux)
# SSoT: docs/for_ai/spec/api_and_rules.md "환경 변수" 절
# =====================================================================

# ----- Backend -----------------------------------------------------
# DB 접속 문자열. docker compose 안에서는 호스트가 'db' 이다.
DATABASE_URL=postgres://exp:exp@db:5432/expcalendar?sslmode=disable

# JWT 서명용 비밀키. 운영 환경에서는 32바이트 이상의 랜덤 값으로 반드시 교체할 것.
JWT_SECRET=change-me-to-random-32-bytes
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=14

# DEV_MODE=true 이면 /api/auth/dev-login (이메일/이름만으로 즉시 로그인) 이 활성화된다.
DEV_MODE=true
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000

# Google OAuth (선택)
# 비워두면 Google 로그인 비활성, dev-login 만으로 진행 가능.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Gemini (선택)
# 비워두면 LLM 페르소나가 결정적 mock 응답으로 폴백한다.
GEMINI_API_KEY=
LLM_MODEL=gemini-3.5-flash

# ----- Frontend ----------------------------------------------------
# 브라우저(호스트) 에서 백엔드에 직접 접근하므로 localhost 가 맞다.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# GOOGLE_OAUTH_CLIENT_ID 와 동일한 값을 넣어준다.
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# true 이면 랜딩 페이지에 "개발용 로그인" 폼이 노출된다.
NEXT_PUBLIC_DEV_MODE=true
